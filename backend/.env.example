# Database / queue
DATABASE_URL=postgresql+psycopg2://ocr:ocr@postgres:5432/ocr
REDIS_URL=redis://redis:6379/0

# Storage roots (inside container)
STORAGE_INPUT=/data/input
STORAGE_OUTPUT=/data/output
STORAGE_TEMP=/data/temp

# OCR
OCR_LANG=en
OCR_MIN_CONFIDENCE=0.5

# Default LLM provider (external OpenAI-compatible). KEY IS SERVER-SIDE ONLY.
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-v4-flash
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=
LLM_TIMEOUT=60

# Optional other providers (selectable from frontend)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OLLAMA_BASE_URL=http://ollama:11434/v1
