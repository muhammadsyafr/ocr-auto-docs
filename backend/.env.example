# Database / queue
DATABASE_URL=postgresql+psycopg2://ocr:ocr@postgres:5432/ocr
REDIS_URL=redis://redis:6379/0

# Storage roots (inside container)
STORAGE_INPUT=/data/input
STORAGE_OUTPUT=/data/output
STORAGE_TEMP=/data/temp

# OCR
OCR_LANG=id
OCR_MIN_CONFIDENCE=0.5

# Default custom LLM provider (OpenAI-compatible). KEY IS SERVER-SIDE ONLY.
LLM_PROVIDER=custom
LLM_MODEL_DEFAULT=
LLM_API_KEY_CUSTOM=
LLM_BASE_URL_CUSTOM=
LLM_MODELS_CUSTOM=
LLM_TIMEOUT=60
